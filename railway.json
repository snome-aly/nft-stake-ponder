{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "buildCommand": "node .yarn/releases/yarn-3.2.3.cjs install --immutable && node .yarn/releases/yarn-3.2.3.cjs ponder:typecheck"
  },
  "deploy": {
    "startCommand": "node .yarn/releases/yarn-3.2.3.cjs ponder:start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
